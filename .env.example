# Copy this file to .env and fill in your values.
# On shared hosting you can set these via .htaccess:
#   SetEnv DB_HOST localhost
# Or via your hosting control panel's environment variable settings.

APP_ENV=production
APP_DEBUG=false

DB_HOST=localhost
DB_PORT=3306
DB_NAME=student_database
DB_USER=your_db_user
DB_PASS=your_db_password

# Outgoing mail — required for the "Passwort vergessen" (password reset) link.
#
# MAIL_DRIVER=native (default) hands off to PHP's built-in mail() function,
# i.e. the server's local mail system. This works on most shared hosting —
# including hosts that block PHP scripts from opening their own outbound
# socket connections to SMTP ports, which is a common restriction and will
# make MAIL_DRIVER=smtp below fail with a connection timeout/error.
#
# MAIL_DRIVER=smtp speaks SMTP directly to an external mailbox/relay and
# needs the SMTP_* settings filled in (get them from your mailbox's settings,
# e.g. cPanel > Email Accounts > Connect Devices / Configure Mail Client).
# SMTP_ENCRYPTION is "tls" for STARTTLS (usually port 587) or "ssl" for
# implicit TLS (usually port 465).
MAIL_DRIVER=native
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Lernmonitor

SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=
SMTP_PASS=

# Optional: base URL used to build links in outgoing emails. Leave unset to
# auto-detect from the incoming request (scheme + host) — only needed if
# that auto-detection is wrong (e.g. behind certain reverse proxies).
APP_URL=
